#!/bin/sh

. _LIBRARY_PATH_/_APPLICATION_NAME_/init.sh

if [ $# -le 0 ]; then
	_exitWithError "CMD required (-get, -find, -put, -delete)" 1
fi

case $1 in
-get | -g)
	shift
	. _LIBRARY_PATH_/_APPLICATION_NAME_/cmds/get.sh
	;;

-find | -f)
	shift
	. _LIBRARY_PATH_/_APPLICATION_NAME_/cmds/find.sh
	;;

-put | -p)
	shift
	. _LIBRARY_PATH_/_APPLICATION_NAME_/cmds/put.sh
	;;

# cannot use -d since it conflicts with debug
-delete)
	. _LIBRARY_PATH_/_APPLICATION_NAME_/cmds/delete.sh
	;;

esac
